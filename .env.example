# ============================================================
# Copy this file to .env and adjust values for local dev.
# .env is gitignored — never commit secrets.
# ============================================================

# --- Postgres ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=campaign_manager
POSTGRES_PORT=5432

# --- Backend API ---
NODE_ENV=development
API_PORT=4000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/campaign_manager
TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5432/campaign_manager_test
JWT_SECRET=replace-me-with-a-long-random-string

JWT_EXPIRES_IN=1h
CORS_ORIGINS=http://localhost:5173

# --- Frontend ---
WEB_PORT=5173
VITE_API_URL=http://localhost:4000
